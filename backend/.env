# Database Configuration
DATABASE_URL=mysql+pymysql://root@localhost:3306/autofill_db

# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME=AutoFill AI System

# CORS Configuration
BACKEND_CORS_ORIGINS=["http://localhost", "http://localhost:3000", "http://localhost:8000"]

# AI Configuration
TOP_SUGGESTIONS_COUNT=3
HISTORY_LOOKBACK_DAYS=30
MIN_HISTORY_ENTRIES=5

# AI Provider Configuration
AI_PROVIDER=openrouter
AI_PROFILE=auto
AI_FAILOVER_ENABLED=true
AI_MODEL=openai/gpt-oss-120b:free

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODELS=gpt-4o-mini,gpt-4o,gpt-3.5-turbo

# OpenRouter Configuration
OPENROUTER_API_KEY=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
OPENROUTER_MODEL=google/gemma-3-4b-it:free
OPENROUTER_FALLBACK_MODELS=openai/gpt-4o-mini,openai/gpt-4o,anthropic/claude-3-haiku,meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_AUTO_FAILOVER=true
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=AutoFill AI System
